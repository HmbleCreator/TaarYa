# =============================================================================
# TaarYa — Environment Configuration Template
# =============================================================================
# Copy this to .env and fill in your values:
#   cp .env.example .env
#
# All settings can also be set via environment variables (see below).
# =============================================================================

# ── Database URLs ─────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+psycopg2://taarya:taarya123@localhost:5432/astronomy

# ── Qdrant (Vector DB) ───────────────────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333
# QDRANT_API_KEY=your_api_key_here        # for Qdrant Cloud

# ── Neo4j (Graph DB) ──────────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=taarya123

# ── Embedding Model ──────────────────────────────────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── LLM (optional — for agentic chat interface) ──────────────────────────────
OPENAI_API_KEY=your_openai_key_here
# ANTHROPIC_API_KEY=your_anthropic_key_here
# OLLAMA_BASE_URL=http://localhost:11434

# ── Server ───────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
WORKERS=1
LOG_LEVEL=INFO

# ── SIMBAD / Astroquery ──────────────────────────────────────────────────────
SIMBAD_TIMEOUT=10

# ── Development ───────────────────────────────────────────────────────────────
DEBUG=false
